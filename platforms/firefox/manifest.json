{
  "manifest_version": 2,
  "name": "ClawdMate",
  "version": "1.0.0",
  "description": "Download slides, notes, assignments, QA, and QB from PESU Academy — merge PDFs, zip files, one click.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "https://www.pesuacademy.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.pesuacademy.com/Academy/*"],
      "js": ["loader.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    "lib/*",
    "content.js"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "clawdmate@pesuacademy",
      "strict_min_version": "91.0"
    }
  }
}
